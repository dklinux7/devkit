# generate writes extra_targets from workspace.yaml
env DEVKIT_HOME=$WORK/devkit-home
mkdir $WORK/project

exec devkit init
cp $WORK/workspace.yaml $WORK/devkit-home/workspace.yaml
exec devkit generate $WORK/project
exists $WORK/project/custom/tool.md

-- workspace.yaml --
name: "Test User"
active_context: work
extra_targets:
  - custom/tool.md
