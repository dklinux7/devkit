# generate writes .cursor/rules/devkit-context.mdc with frontmatter
env DEVKIT_HOME=$WORK/devkit-home
mkdir $WORK/project

exec devkit init
cp $WORK/workspace.yaml $WORK/devkit-home/workspace.yaml
exec devkit generate $WORK/project
exists $WORK/project/.cursor/rules/devkit-context.mdc
grep 'alwaysApply: true' $WORK/project/.cursor/rules/devkit-context.mdc
grep 'Generated by devkit' $WORK/project/.cursor/rules/devkit-context.mdc

-- workspace.yaml --
name: "Test User"
active_context: work
