# generate writes all AI config files to the target directory
env DEVKIT_HOME=$WORK/devkit-home
mkdir $WORK/project

exec devkit init
cp $WORK/workspace.yaml $WORK/devkit-home/workspace.yaml
exec devkit generate $WORK/project
stdout '✓ Generated 5 files'
stdout 'CLAUDE.md'
stdout 'AGENTS.md'

exists $WORK/project/CLAUDE.md
exists $WORK/project/AGENTS.md
exists $WORK/project/.cursorrules
exists $WORK/project/.windsurfrules
exists $WORK/project/copilot-instructions.md

grep 'Generated by devkit' $WORK/project/CLAUDE.md

-- workspace.yaml --
name: "Test User"
active_context: work
